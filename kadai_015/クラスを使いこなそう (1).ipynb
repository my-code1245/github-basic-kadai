        "class Human:\n",
        "  def __init__(self,name,age):\n",
        "    self.name = name\n",
        "    self.age = age\n",
        "\n",
        "  def printinfo(self):\n",
        "    print(\"名前\",self.name)\n",
        "    print(\"年齢\",self.age)\n",
        "\n",
        "human = Human(\"侍太郎\",30)\n",
        "\n",
        "human.printinfo()\n",
